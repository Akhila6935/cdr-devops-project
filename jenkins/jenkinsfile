pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/your-username/cdr-devops-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t cdr-app -f docker/Dockerfile .'
            }
        }

        stage('Run') {
            steps {
                sh 'docker run -d -p 5000:5000 cdr-app'
            }
        }
    }
}